rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if user belongs to the family
    function isFamilyMember(familyId) {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId == familyId;
    }

    // Helper: validate transaction fields (mirrors client-side zod schema)
    // 주의: 카테고리 추가 시 categories.ts와 이 목록을 동시에 업데이트할 것
    function isValidTransaction(data) {
      return data.type in ['expense', 'income'] &&
        data.amount is int &&
        data.amount > 0 &&
        data.amount <= 1000000000 &&
        data.category in [
          '식비', '카페', '쇼핑', '구독', '간식',
          '교통', '관리비', '기타', '건강', '통신비', '취미',
          '급여', '환급', '용돈', '청약', '기타수입'
        ] &&
        data.name is string &&
        data.name.size() >= 1 &&
        data.name.size() <= 100 &&
        data.yearMonth is string &&
        data.yearMonth.size() == 7 &&
        data.memo is string &&
        data.memo.size() <= 200 &&
        data.createdBy == request.auth.uid;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && request.auth.uid == userId;
    }

    // 초대 코드 — 읽기: 인증 사용자 전체(join 조회 필요), 쓰기: 해당 가족 멤버만
    match /inviteCodes/{code} {
      allow read: if isAuth();
      allow create: if isAuth() &&
        isFamilyMember(request.resource.data.familyId);
      allow delete: if isAuth() &&
        isFamilyMember(resource.data.familyId);
    }

    // Families collection — 읽기: 멤버 전용
    match /families/{familyId} {
      allow read: if isFamilyMember(familyId);
      allow create: if isAuth();
      // 기존 멤버는 모든 업데이트 허용, 신규 멤버는 자신을 members에 추가하는 경우만 허용 (중복 추가 불가)
      allow update: if isFamilyMember(familyId) ||
        (isAuth() &&
         request.resource.data.members.hasAll(resource.data.members) &&
         request.auth.uid in request.resource.data.members &&
         !(request.auth.uid in resource.data.members));

      // Transactions
      match /transactions/{txId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId) && isValidTransaction(request.resource.data);
        allow update: if isFamilyMember(familyId) && isValidTransaction(request.resource.data);
        allow delete: if isFamilyMember(familyId);
      }

      // Recurring Transactions
      match /recurringTransactions/{recurringId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId);
        allow delete: if isFamilyMember(familyId);
      }

      // Monthly Summaries — Cloud Functions(onTransactionWrite)가 계산/쓰기
      // TODO: functions 배포 및 검증 완료 후 아래 write를 false로 변경
      match /monthlySummaries/{yearMonth} {
        allow read: if isFamilyMember(familyId);
        allow write: if isFamilyMember(familyId); // Cloud Functions 검증 후 → false
      }

      // Overview
      match /overview/{yearMonth} {
        allow read: if isFamilyMember(familyId);
        allow write: if isFamilyMember(familyId);
      }

      // Goals
      match /goals/{goalId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId);
        allow delete: if isFamilyMember(familyId);
      }

      // Financial Status
      match /financialStatus/{yearMonth} {
        allow read: if isFamilyMember(familyId);
        allow write: if isFamilyMember(familyId);

        match /accounts/{accountId} {
          allow read: if isFamilyMember(familyId);
          allow write: if isFamilyMember(familyId);
        }
      }
    }
  }
}
